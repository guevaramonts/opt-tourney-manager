# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=opt_app
DB_USER=opt_user
DB_PASSWORD=change_me_strong_password

# Server
PORT=3001
CLIENT_ORIGIN=https://opt-poker.com

# Firebase project ID (used to verify admin JWT tokens)
FIREBASE_PROJECT_ID=opt-poker

# Admin UIDs from Firebase Authentication → Users table (comma-separated)
ADMIN_UID_WHITELIST=uid1,uid2
